# Swift Package Manager
.build/
.swiftpm/
Package.resolved.backup

# Xcode (in case the package is opened in Xcode)
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
.DS_Store

# Build output of scripts/build-app.sh (Increment 4)
Freest.app/
dist/

# Downloaded ML models must never be committed. They live in
# ~/Library/Application Support/Freest/models/ at runtime; any stray in-repo
# copy is ignored here as a safety net.
models/
*.mlmodelc/
*.mlpackage/

# Local runtime config (should never be in the repo)
config.json

# Editor / OS cruft
*.swp
.idea/
.vscode/

# Local planning docs (reference Vox / Amazon-internal details — never publish)
plans/

# Local dev tooling (Playwright MCP for browser testing) — not part of the product
.mcp.json
